          "category": "security",
          "owner": "security-team",
          "compliance": "critical",
          "threat-prevention": "brute-force"
        },
        "log": {
          "atSessionStart": false,
          "atSessionEnd": true,
          "logForwarding": "security-siem"
        },
        "schedule": null,
        "negate": {
          "source": false,
          "destination": false
        },
        "disabled": false,
        "hipProfiles": []
      },
