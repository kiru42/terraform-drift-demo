  "metadata": {
    "lastModified": "2026-04-06T15:55:00Z",
    "modifiedBy": "terraform",
    "version": "1.0.0",
    "changeControl": {
      "ticketId": "CHG-2024-001",
      "approver": "security-team@company.com",
      "approvalDate": "2026-04-06"
    },
    "documentation": "https://wiki.company.com/firewall-policies"
  },
  "globalSettings": {
    "defaultAction": "deny",
    "logAllDenied": true,
    "sessionTimeout": 3600,
    "tcpTimeout": 3600,
    "udpTimeout": 30,
    "maxSessionsPerHost": 10000
  },
  "serviceDefinitions": {
    "custom-services": [
      {
        "name": "custom-app-port",
        "protocol": "tcp",
        "port": "8080-8090",
        "description": "Custom application port range"
      },
      {
        "name": "voip-sip",
        "protocol": "udp",
        "port": "5060-5061",
        "description": "VoIP SIP signaling"
      }
    ]
  },
  "addressObjects": {
    "definitions": [
      {
        "name": "vpn-users",
        "type": "ip-netmask",
        "value": "192.168.50.0/24",
        "description": "VPN user pool"
      },
      {
        "name": "dmz-web-servers",
        "type": "ip-range",
        "value": "10.100.10.10-10.100.10.20",
        "description": "DMZ web server farm"
      },
      {
        "name": "database-cluster",
        "type": "fqdn",
        "value": "db-cluster.internal.company.com",
        "description": "Database cluster DNS name"
      }
    ]
  },
  "applicationFilters": {
    "custom-filters": [
      {
        "name": "social-media",
        "applications": [
          "facebook",
          "twitter",
          "instagram",
          "linkedin"
        ],
        "category": "social-networking"
      },
      {
        "name": "file-sharing",
        "applications": [
          "dropbox",
          "google-drive",
          "onedrive",
          "box"
        ],
        "category": "collaboration"
      }
    ]
  },
  "securityProfiles": {
    "antivirus": [
      {
        "name": "default-av-profile",
        "decoders": [
          "http",
          "smtp",
          "pop3",
          "imap",
          "ftp"
        ],
        "action": "reset-both"
      }
    ],
    "antiSpyware": [
      {
        "name": "strict-anti-spyware",
        "threatException": [],
        "botnetDomains": {
          "lists": [
            "panw-known-malicious-domains"
          ],
          "action": "block"
        }
      }
    ],
    "vulnerability": [
      {
        "name": "strict-vulnerability",
        "criticalSeverity": "reset-both",
        "highSeverity": "reset-both",
        "mediumSeverity": "alert",
        "lowSeverity": "default"
      }
    ],
    "urlFiltering": [
      {
        "name": "strict-browsing",
        "blockedCategories": [
          "adult",
          "gambling",
          "malware",
          "phishing",
          "proxy-avoidance",
          "hacking",
          "command-and-control"
        ],
        "action": "block",
        "logContainer": true
      }
    ],
    "fileBlocking": [
      {
        "name": "sensitive-data-profile",
        "blockedFileTypes": [
          "pe",
          "exe",
          "dll",
          "bat",
          "cmd",
          "vbs",
          "ps1"
        ],
        "action": "block",
        "direction": "both"
      }
    ],
    "dataFiltering": [
      {
        "name": "pci-dss-data-filter",
        "dataPatterns": [
          "credit-card-numbers",
          "ssn",
          "iban"
        ],
        "action": "alert",
        "logSeverity": "critical"
      }
    ],
    "wildfire": [
      {
        "name": "wildfire-analysis",
        "fileSize": 10,
        "forwardMethod": "cloud",
        "schedule": "real-time"
      }
    ]
  },
  "comments": {
    "schema-version": "This is an exhaustive example of Panorama firewall configuration",
    "key-concepts": {
      "security-rules": "Order matters! Rules are evaluated top-to-bottom",
      "action-types": {
        "allow": "Permit traffic and continue inspection",
        "deny": "Block traffic and send TCP reset or ICMP unreachable",
        "drop": "Silently discard traffic (no notification to source)"
      },
      "logging": {
        "atSessionStart": "Log when connection begins",
        "atSessionEnd": "Log when connection closes (recommended)",
        "logForwarding": "Name of log forwarding profile"
      },
      "advanced-features": {
        "user-id": "Identity-based policies (sourceUser, destinationUser)",
        "hip-profiles": "Host Information Profile (endpoint compliance)",
        "qos": "Quality of Service (traffic prioritization)",
        "schedule": "Time-based rules (business hours, maintenance windows)",
        "application-control": "Layer 7 application identification",
        "url-filtering": "Category-based web filtering",
        "threat-prevention": "Antivirus, anti-spyware, vulnerability protection",
        "wildfire": "Advanced malware analysis (sandbox)",
        "data-filtering": "DLP (Data Loss Prevention)"
      },
      "best-practices": {
        "naming": "Use descriptive rule names (verb_object_context)",
        "description": "Always document the business purpose",
        "tags": "Categorize for reporting and compliance",
        "logging": "Enable logging for security rules, minimize for high-volume traffic",
        "disabled-rules": "Keep disabled rules for emergency scenarios",
        "review-schedule": "Review rules quarterly, remove unused"
      }
    },
    "rule-ordering": "Most specific rules first, default deny last",
    "testing": "Always test in non-production before deploying to production"
  }
}
