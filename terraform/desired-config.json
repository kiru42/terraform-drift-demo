        "destination": [
          "corporate-network",
          "10.50.0.0/16"
        ],
        "service": [
          "application-default",
          "tcp/443",
          "udp/1194"
        ],
        "action": "allow",
        "enabled": true,
        "description": "Allow VPN users to access corporate resources",
        "tags": {
          "category": "remote-access",
          "owner": "it-team",
          "compliance": "standard"
        },
        "log": {
          "atSessionStart": true,
          "atSessionEnd": true,
          "logForwarding": "vpn-logs"
