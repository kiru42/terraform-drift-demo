        "vulnerability": "strict-vulnerability",
        "fileBlocking": "sensitive-data-profile",
        "dataFiltering": "pci-dss-data-filter",
        "wildfire": "wildfire-analysis"
      },
      {
        "name": "deny_p2p_protocols",
        "source": [
          "any"
